def plot_confusion_matrix_for_fold(all_labels, all_preds, label_encoder, fold, save_dir='models/zq_cv'):
    """绘制单次折叠的混淆矩阵"""
    os.makedirs(save_dir, exist_ok=True)

    # 计算混淆矩阵
    cm = confusion_matrix(all_labels, all_preds)

    # 使用标签编码器获取类别名称
    class_names = [str(int(label_encoder.inverse_transform([i])[0])) + '%' for i in range(len(label_encoder.classes_))]

    # 绘制混淆矩阵
    plt.figure(figsize=(10, 8))
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=class_names, yticklabels=class_names)
    plt.title(f'Confusion Matrix - Fold {fold + 1}')
    plt.ylabel('True Label')
    plt.xlabel('Predicted Label')
    plt.tight_layout()

    save_path = os.path.join(save_dir, f'fold_{fold + 1}_confusion_matrix.png')
    plt.savefig(save_path, dpi=300)
    plt.close()
    print(f"Confusion matrix for Fold {fold + 1} saved to: {save_path}")


